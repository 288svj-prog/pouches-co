{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm --prefix site install && npm --prefix site run build"
  },
  "deploy": {
    "startCommand": "npx -y serve site/dist -s -l $PORT --no-clipboard",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
